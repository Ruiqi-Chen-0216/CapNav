# .env.example
# All paths must be ABSOLUTE paths.
CAPNAV_PROMPT_ROOT=/ABS/PATH/TO/generated_prompts
CAPNAV_GRAPH_DIR=/ABS/PATH/TO/ground_truth/graphs
CAPNAV_VIDEO_ROOT=/ABS/PATH/TO/videos_64frames_1fps
CAPNAV_RESULT_ROOT=/ABS/PATH/TO/results


# Recommended
HF_HOME=/ABS/PATH/TO/hf_cache

# or
HF_HUB_CACHE=/ABS/PATH/TO/hf_cache/hub



# Optional: only if using Spatial-MLLM code repo (NOT weights)
SPATIAL_MLLM_ROOT=/abs/.../Spatial-MLLM
